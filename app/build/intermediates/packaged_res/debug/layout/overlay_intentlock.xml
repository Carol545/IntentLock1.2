<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F00D1B2A">

    <!-- Dismiss button top right -->
    <ImageButton
        android:id="@+id/btnDismiss"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="#8BADB9"
        android:contentDescription="Dismiss" />

    <!-- Main prediction layout -->
    <LinearLayout
        android:id="@+id/layoutPrediction"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:id="@+id/ivAppIcon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:contentDescription="App icon" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="App Name" />

        <TextView
            android:id="@+id/tvConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textColor="#00C9A7"
            android:text="85% match" />

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="16sp"
            android:textColor="#8BADB9"
            android:text="Opening in 3s" />

        <Button
            android:id="@+id/btnNotThis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Not this"
            android:textColor="#8BADB9"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <!-- Quick pick grid (hidden by default) -->
    <GridLayout
        android:id="@+id/layoutQuickPick"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:columnCount="2"
        android:rowCount="2"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Mic button bottom left -->
    <ImageButton
        android:id="@+id/btnMic"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_btn_speak_now"
        android:background="@drawable/circle_button_bg"
        android:tint="#00C9A7"
        android:contentDescription="Voice capture" />

</FrameLayout>

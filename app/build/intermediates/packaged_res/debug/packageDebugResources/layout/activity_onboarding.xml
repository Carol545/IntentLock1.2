<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <!-- Standard Steps Layout -->
    <LinearLayout
        android:id="@+id/layoutStandardSteps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp">

        <TextView
            android:id="@+id/tvStepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 4"
            android:textColor="#8BADB9"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:text="Step Title" />

        <TextView
            android:id="@+id/tvStepDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="15sp"
            android:textColor="#8BADB9"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="Step description goes here." />

        <Button
            android:id="@+id/btnGrant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Grant Permission"
            android:backgroundTint="#00C9A7"
            android:textColor="#0D1B2A"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Next"
            android:backgroundTint="#1A8BADB9"
            android:textColor="#8BADB9" />
    </LinearLayout>

    <!-- App Schedule Layout (Hidden by default) -->
    <LinearLayout
        android:id="@+id/layoutScheduleStep"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App Schedule"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tell us which apps you need and when."
            android:textColor="#8BADB9"
            android:textSize="14sp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:id="@+id/containerSchedules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <Button
            android:id="@+id/btnAddSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add App Rule"
            android:backgroundTint="#1A8BADB9"
            android:textColor="#00C9A7"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnFinishOnboarding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Finish Setup"
            android:backgroundTint="#00C9A7"
            android:textColor="#0D1B2A"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
